QWidget { background:#0b0f1a; color:#d8ecff; font-size:13px; }
QListWidget { background:#111827; border:1px solid #1f2937; }
QListWidget::item:selected { background:#00ff7f; color:#081018; }
QPushButton { background:#1f2937; border:1px solid #00ff7f; padding:6px 10px; border-radius:6px; }
QPushButton:hover { background:#253246; }
QLineEdit, QComboBox, QSpinBox { background:#0f172a; border:1px solid #334155; padding:6px; }
QTableWidget { gridline-color:#334155; selection-background-color:#00ff7f; selection-color:#081018; }
QHeaderView::section { background:#111827; border:1px solid #334155; padding:4px; }
